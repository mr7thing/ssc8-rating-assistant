{
  "manifest_version": 3,
  "name": "SSC8 Rating Assistant",
  "version": "1.0.1",
  "description": "Multi-dimensional song rating and sorting for songcontest.ai",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://www.songcontest.ai/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_title": "Open SSC8 Dashboard"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.songcontest.ai/*"
      ],
      "js": [
        "scripts/content.js"
      ],
      "css": [
        "styles/shared.css",
        "styles/content.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}